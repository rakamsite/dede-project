# Ignore all themes/plugins by default
/wp-content/themes/*
/wp-content/plugins/*

# Allow only DeDe project theme/plugins
!/wp-content/themes/DeDeTemPlate/
!/wp-content/themes/DeDeTemPlate/**

!/wp-content/themes/dede-theme/
!/wp-content/themes/dede-theme/**
!/wp-content/themes/dede-*/
!/wp-content/themes/dede-*/**

