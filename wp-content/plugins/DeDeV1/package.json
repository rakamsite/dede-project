{
  "name": "my-webpack-project",
  "version": "1.0.0",
  "description": "My webpack project",
  "main": "tailwind.config.js",
  "scripts": {
    "dedetw": "npx tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/style.css --watch",
